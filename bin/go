#!/usr/bin/env ruby
require 'optparse'

def show_help
  puts <<~EOF
    Usage: #{File.basename($PROGRAM_NAME)} <command> [options]

    Commands:
      write-changelog    Generate/update the changelog (replace the placeholder with your actual command)
      env                Start the python virtual environment

    Options:
      -h, --help         Show this help message
  EOF
end

# No args → help
if ARGV.empty?
  show_help
  exit 1
end

# Global options
OptionParser.new do |opts|
  opts.on('-h', '--help') do
    show_help
    exit 0
  end
end.order!(ARGV) rescue begin
  show_help
  exit 1
end

# Subcommand dispatch
cmd = ARGV.shift
case cmd
when 'write-changelog'
  # run via shell so redirection works
  system('git log --pretty=format:"%cd (%h) %s" --stat > changelog.txt')
  puts 'Did write-changelog…'
when 'env'
  puts "To activate your virtualenv, run:"
  puts "  source ./env/bin/activate"
else
  warn "Error: Unknown command '#{cmd}'"
  show_help
  exit 1
end